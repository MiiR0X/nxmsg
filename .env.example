PORT=3000
DATABASE_URL=postgresql://user:password@host:5432/dbname
NXMSG_DISABLE_WS=false
NXMSG_RENDER_KEEPALIVE_ENABLED=true
NXMSG_KEEPALIVE_INTERVAL_MS=300000
NXMSG_KEEPALIVE_STARTUP_DELAY_MS=45000
NXMSG_KEEPALIVE_TIMEOUT_MS=15000
NXMSG_KEEPALIVE_TARGET_URL=
NXMSG_STUN_URL=stun:stun.l.google.com:19302
NXMSG_TURN_URL=
NXMSG_TURN_USERNAME=
NXMSG_TURN_PASSWORD=

# Firebase service account for server-side FCM.
# Preferred: path to JSON file (for local dev).
FIREBASE_SERVICE_ACCOUNT_PATH=./secrets/push-service-account.json
# Alternative for hosting (Render/Railway): raw JSON or base64-encoded JSON.
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_SERVICE_ACCOUNT_JSON_BASE64=
